# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Required in production; locally Auth.js infers it. Set to your deployed URL.
AUTH_URL=http://localhost:3000
# Trust the host header (needed on Vercel / behind a proxy).
AUTH_TRUST_HOST=true

# OAuth providers — Auth.js v5 reads AUTH_<PROVIDER>_ID / _SECRET by convention.
# Google:  https://console.cloud.google.com  → Credentials → OAuth client ID
#   Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# GitHub:  Settings → Developer settings → OAuth Apps
#   Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────
# Pooled connection string (used at runtime).
DATABASE_URL=
# Direct (non-pooled) connection — used by `prisma migrate`. Optional for db push.
DIRECT_URL=

# ─── Liveblocks (Phase 3) ────────────────────────────────────────────────
LIVEBLOCKS_SECRET_KEY=
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=

# ─── AI: Google Gemini via Vercel AI SDK (Phase 4) ───────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── Rate limiting (Upstash Redis) ───────────────────────────────────────
# Optional. When both are set, AI endpoints use a distributed (cross-instance)
# limiter; otherwise they fall back to a per-instance in-memory limiter (fine for
# local dev, not for serverless prod). Create a free database at console.upstash.com
# → Redis → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional fallback key used if the primary Gemini key is rate-limited
GOOGLE_GENERATIVE_AI_API_KEY_BACKUP=

# tldraw Hobby license key (Phase 2 canvas). Leave blank for local dev —
# required only for production HTTPS deploys. Get one at tldraw.dev.
NEXT_PUBLIC_TLDRAW_LICENSE_KEY=
